{
  "compilerOptions": {
    // 是否始终使用严格模式
    "alwaysStrict": false,
    // 是否生成声明文件
    "declaration": true,
    // 是否为声明文件生成 source map
    "declarationMap": true,
    // 是否降级迭代器以兼容旧版本环境
    "downlevelIteration": true,
    // 是否从 tslib 导入辅助函数
    "importHelpers": true,
    // 是否在 source map 中内联源代码
    "inlineSources": true,
    // 是否确保每个文件可以独立编译（适用于 Babel 等工具）
    "isolatedModules": true,
    // 编译时包含的库文件
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    // 模块解析策略
    "moduleResolution": "bundler",
    // 是否禁用错误信息截断
    "noErrorTruncation": true,
    // 是否禁止 switch 语句中的 case 落空
    "noFallthroughCasesInSwitch": true,
    // 是否要求函数中所有代码路径都有返回值
    "noImplicitReturns": true,
    // 是否报告未使用的局部变量
    "noUnusedLocals": false,
    // 是否报告未使用的函数参数
    "noUnusedParameters": false,
    // 是否在监听模式下保留输出
    "preserveWatchOutput": true,
    // 是否生成 source map 文件
    "sourceMap": true,
    // 是否启用所有严格类型检查选项
    "strict": true,
    // 是否对 bind/call/apply 进行严格检查
    "strictBindCallApply": false,
    // 编译目标 JavaScript 版本
    "target": "esnext",
    // 是否对索引访问进行未定义检查
    "noUncheckedIndexedAccess": true
  },
  // 项目引用配置，用于 monorepo 结构
  "references": [
    {
      // 引用的子项目路径
      "path": "./packages/layout-engine"
    }
  ],
  // 包含的文件列表，为空表示由引用的项目处理
  "include": []
}
